---
import type { LedgerPost } from '../lib/beehiiv';

interface Props {
  showInstagram?: boolean;
  posts?: LedgerPost[];
}

const { showInstagram = false, posts = [] } = Astro.props;
---

<footer>
  <section class:list={['footer-reads', posts.length === 0 && 'footer-reads-empty']} aria-labelledby="footer-reads-title" data-beehiiv-footer-feed>
    <div class="footer-reads-header">
      <h2 id="footer-reads-title">Recent Reads</h2>
      <div class="footer-reads-rule"></div>
    </div>
    <div class="footer-reads-list">
      {posts.length > 0 && (
        <>
        {posts.map((post) => (
          <a href={post.url} class="footer-read">
            <span class="footer-read-date">{post.date}</span>
            <span class="footer-read-title">{post.title}</span>
          </a>
        ))}
        </>
      )}
    </div>
  </section>
  <img src="/images/orange-bigblock.png" alt="The Litchfield Ledger" class="footer-logo-img" width="715" height="508" loading="lazy" decoding="async" />
  <div class="beehiiv-wrap" style="margin-top: 0;">
    <script is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="48c597c3-c9e3-4c7a-b09b-db8627e0a48e"></script>
  </div>
  <div class="footer-support">
    <p>The Ledger is free and independent. If you find value in it, consider supporting it.</p>
    <a href="https://litchfieldledger.beehiiv.com/upgrade">Support the Ledger</a>
  </div>
  {showInstagram && (
    <div class="footer-social">
      <a href="https://www.instagram.com/litchfieldledger/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <img src="/images/instagram-logo.png" alt="Instagram" width="1676" height="1675" loading="lazy" decoding="async" />
      </a>
    </div>
  )}
  <div class="footer-nav">
    <a href="mailto:patrick@litchfieldledger.com">Contact</a>
  </div>
  <p class="footer-copy">© 2026 The Litchfield Ledger</p>
</footer>
