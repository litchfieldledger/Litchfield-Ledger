---
import type { LedgerPost } from '../lib/beehiiv';

interface Props {
  showInstagram?: boolean;
  latestPost?: LedgerPost;
}

const { showInstagram = false, latestPost } = Astro.props;
---

<footer>
  <section class:list={['latest-issue', !latestPost && 'latest-issue-empty']} aria-labelledby="latest-issue-title" data-beehiiv-latest-preview>
    <div class="latest-issue-inner">
      <div class="latest-issue-content">
        <div class="latest-issue-kicker">
          <span>This Week</span>
          {latestPost?.date && <span>{latestPost.date}</span>}
        </div>
        {latestPost ? (
          <>
            <a href={latestPost.url} class="latest-issue-title" id="latest-issue-title">{latestPost.title}</a>
            {latestPost.excerpt && (
              <div class="latest-issue-preview">
                <p>{latestPost.excerpt}</p>
              </div>
            )}
          </>
        ) : (
          <>
            <span class="latest-issue-title" id="latest-issue-title">Latest Issue</span>
            <div class="latest-issue-preview"></div>
          </>
        )}
      </div>
      <div class="latest-issue-gate">
        <h3>Your week is waiting. Join The Litchfield Ledger.</h3>
        <div class="beehiiv-wrap latest-issue-signup">
          <script is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="48c597c3-c9e3-4c7a-b09b-db8627e0a48e"></script>
        </div>
        <p>Free, every Tuesday.</p>
      </div>
    </div>
  </section>
  <img src="/images/orange-bigblock.png" alt="The Litchfield Ledger" class="footer-logo-img" width="715" height="508" loading="lazy" decoding="async" />
  <div class="footer-support">
    <p>The Ledger is free and independent. If you find value in it, consider supporting it.</p>
    <a href="https://litchfieldledger.beehiiv.com/upgrade">Support the Ledger</a>
  </div>
  {showInstagram && (
    <div class="footer-social">
      <a href="https://www.instagram.com/litchfieldledger/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <img src="/images/instagram-logo.png" alt="Instagram" width="1676" height="1675" loading="lazy" decoding="async" />
      </a>
    </div>
  )}
  <div class="footer-nav">
    <a href="mailto:patrick@litchfieldledger.com">Contact</a>
  </div>
  <p class="footer-copy">© 2026 The Litchfield Ledger</p>
</footer>
