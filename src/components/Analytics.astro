---
const gaId = 'G-P31K2EFL2L';
const clarityId = 'wmug74fcme';
---

<script is:inline define:vars={{ gaId, clarityId }}>
  (function () {
    const analyticsDelay = 8000;
    const interactionEvents = ['click', 'keydown', 'pointerdown', 'scroll', 'touchstart'];
    let hasLoaded = false;
    let fallbackTimer;

    function loadScript(src) {
      const script = document.createElement('script');
      script.async = true;
      script.src = src;
      document.head.appendChild(script);
    }

    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function () {
      window.dataLayer.push(arguments);
    };

    function loadAnalytics() {
      if (hasLoaded) return;
      hasLoaded = true;

      window.clearTimeout(fallbackTimer);
      interactionEvents.forEach(function (eventName) {
        window.removeEventListener(eventName, loadAnalytics, { passive: true });
      });

      loadScript('https://www.googletagmanager.com/gtag/js?id=' + gaId);
      window.gtag('js', new Date());
      window.gtag('config', gaId);

      window.clarity = window.clarity || function () {
        (window.clarity.q = window.clarity.q || []).push(arguments);
      };
      loadScript('https://www.clarity.ms/tag/' + clarityId);
    }

    interactionEvents.forEach(function (eventName) {
      window.addEventListener(eventName, loadAnalytics, { once: true, passive: true });
    });

    fallbackTimer = window.setTimeout(loadAnalytics, analyticsDelay);
  })();
</script>
