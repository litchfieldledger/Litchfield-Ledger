<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Litchfield Ledger</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=New+Amsterdam&family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Libre+Baskerville:ital@0;1&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --green: #1e3d28;
    --green-mid: #2a5236;
    --orange: #c85c1e;
    --orange-dark: #a84a16;
    --cream: #f0ebe0;
    --cream-dark: #e4ddd0;
    --text-dark: #1a2218;
    --text-mid: #3d4f3a;
    --text-muted: #6b7d68;
  }
  body { font-family: 'Libre Baskerville', Georgia, serif; background: var(--cream); color: var(--text-dark); font-size: 16px; line-height: 1.7; }
  .main-nav { position: absolute; top: 0; left: 0; right: 0; z-index: 10; display: flex; align-items: center; justify-content: space-between; padding: 20px 48px; }
  .nav-logo img { height: 42px; width: auto; display: block; }
  .nav-links { display: flex; align-items: center; gap: 16px; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-family: 'Barlow Condensed', sans-serif; font-size: 14px; letter-spacing: 0.1em; text-transform: uppercase; }
  .nav-submit { border: 1.5px solid rgba(255,255,255,0.5); color: white !important; padding: 8px 20px; border-radius: 2px; transition: border-color 0.2s; }
  .nav-submit:hover { border-color: white; }
  .nav-cta { background: var(--orange) !important; color: white !important; padding: 8px 20px !important; border-radius: 2px; }
  .hero { position: relative; height: 580px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,28,14,0.55) 0%, rgba(15,35,18,0.35) 50%, rgba(8,22,12,0.72) 100%), url('/Connecticut-Mountains.jpg') center center / cover no-repeat; }
  .hero-content { position: relative; z-index: 2; max-width: 680px; padding: 0 24px; }
  .hero-eyebrow { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.22em; text-transform: uppercase; color: white; margin-bottom: 16px; }
  .hero-title { font-family: 'New Amsterdam', sans-serif; font-size: 42px; font-weight: 900; line-height: 0.95; color: white; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .hero-sub { font-family: 'Libre Baskerville', serif; font-style: italic; color: rgba(255,255,255,0.75); font-size: 17px; margin-bottom: 28px; }
  .hero-disclaimer { color: rgba(255,255,255,0.5); font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.05em; font-style: italic; margin-top: 12px; }
  .beehiiv-wrap { width: 100%; max-width: 560px; margin: 0 auto; }
  .beehiiv-wrap iframe { background: transparent !important; }
  .content { max-width: 960px; margin: 0 auto; padding: 56px 48px; display: grid; grid-template-columns: 320px 1fr; gap: 56px; align-items: start; }
  .field-report { border: 1.5px solid #c8bfa8; border-radius: 2px; background: white; overflow: hidden; }
  .widget-header { background: var(--green); padding: 14px 20px; }
  .widget-header-inner { display: flex; justify-content: space-between; align-items: flex-end; }
  .widget-title { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: white; }
  .widget-date { font-family: 'Barlow Condensed', sans-serif; font-size: 12px; letter-spacing: 0.1em; color: rgba(255,255,255,0.6); text-transform: uppercase; margin-top: 2px; }
  .widget-live { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; color: rgba(255,255,255,0.35); letter-spacing: 0.08em; }
  .field-row { display: flex; justify-content: space-between; align-items: baseline; padding: 13px 20px; border-bottom: 1px solid #eee8da; }
  .field-row:last-child { border-bottom: none; }
  .field-label { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
  .field-value { font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 700; color: var(--text-dark); text-align: right; }
  .field-value .unit { font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 600; color: var(--text-muted); margin-left: 4px; }
  .field-value.good { color: var(--green); }
  .field-value.caution { color: var(--orange); }
  .phenology-bar { padding: 16px 20px; border-bottom: 1px solid #eee8da; }
  .pheno-label { font-family: 'Barlow Condensed', sans-serif; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
  .pheno-track { height: 6px; background: #e8e0d0; border-radius: 3px; overflow: hidden; }
  .pheno-fill { height: 100%; border-radius: 3px; background: var(--green); }
  .pheno-stages { display: flex; justify-content: space-between; margin-top: 6px; }
  .pheno-stage { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: #aaa; }
  .pheno-stage.active { color: var(--green); font-weight: 700; }
  .fr-loading { padding: 36px 20px; text-align: center; color: var(--text-muted); font-family: 'Barlow Condensed', sans-serif; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; }
  .widget-cta { padding: 16px 20px; background: var(--cream); border-top: 1px solid #c8bfa8; text-align: center; }
  .widget-cta p { font-size: 13px; color: var(--text-muted); margin-bottom: 10px; font-style: italic; }
  .btn-outline { display: inline-block; padding: 9px 24px; background: var(--orange); color: white; text-decoration: none; font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 2px; }
  .already-sub { display: block; margin-top: 8px; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; color: var(--text-muted); text-decoration: underline; cursor: pointer; }
  .explore-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
  .explore-title { font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--orange); flex-shrink: 0; }
  .explore-rule { flex: 1; height: 1.5px; background: var(--orange); }
  .post-list { list-style: none; }
  .post-item { padding: 18px 0; border-bottom: 1px solid #c8bfa8; cursor: pointer; }
  .post-item:last-child { border-bottom: none; }
  .post-meta { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--orange); margin-bottom: 5px; }
  .post-title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; color: var(--text-dark); line-height: 1.25; text-transform: uppercase; letter-spacing: 0.02em; }
  .post-excerpt { font-size: 14px; color: var(--text-muted); margin-top: 6px; line-height: 1.6; font-style: italic; }
  .subscribe-box { margin-top: 32px; background: var(--green); padding: 28px; border-radius: 2px; }
  .subscribe-box-label { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--orange); margin-bottom: 6px; }
  .subscribe-box-copy { font-style: italic; color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 18px; }
  footer { background: var(--orange); padding: 48px; text-align: center; margin-top: 24px; }
  .footer-logo { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em; color: white; margin-bottom: 8px; }
  .footer-sub { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-bottom: 28px; }
  .footer-nav { margin-top: 20px; }
  .footer-nav a { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.65); text-decoration: none; margin: 0 12px; }
  .footer-copy { margin-top: 20px; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
</style>
</head>
<body>

<nav class="main-nav">
  <a href="/" class="nav-logo">
    <img src="/orange-logo.png" alt="Litchfield Ledger" />
  </a>
  <ul class="nav-links">
    <li><a href="#" class="nav-submit">Submit Your Event</a></li>
    <li><a href="#" class="nav-cta">Subscribe</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">A Northwest Connecticut Newsletter</p>
    <h1 class="hero-title">Exploring<br>Litchfield<br>Hills</h1>
    <p class="hero-sub">Ecology, wildlife, and people of the region.</p>
    <div class="beehiiv-wrap">
      <script is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="48c597c3-c9e3-4c7a-b09b-db8627e0a48e"></script>
    </div>
    <p class="hero-disclaimer">Every week. Free. No spam.</p>
  </div>
</section>

<div class="content">
  <aside>
    <div class="field-report" id="field-report-widget">
      <div class="widget-header">
        <div class="widget-header-inner">
          <div>
            <div class="widget-title">Field Report</div>
            <div class="widget-date" id="fr-date">Loading...</div>
          </div>
          <div class="widget-live" id="fr-live"></div>
        </div>
      </div>
      <div id="fr-body">
        <div class="fr-loading">Fetching field conditions...</div>
      </div>
      <div class="widget-cta">
        <p>Get the full report in your inbox.</p>
        <a href="https://litchfieldledger.com" class="btn-outline">Read This Week's Issue</a>
        <span class="already-sub">Already subscribed?</span>
      </div>
    </div>
  </aside>

  <main>
    <div class="explore-header">
      <span class="explore-title">Explore</span>
      <div class="explore-rule"></div>
    </div>
    <ul class="post-list">
      <li class="post-item">
        <div class="post-meta">Apr 23, 2026</div>
        <div class="post-title">The Oldest Residents</div>
        <div class="post-excerpt">On lichens, geologic time, and what it means to live slowly on stone.</div>
      </li>
      <li class="post-item">
        <div class="post-meta">Apr 16, 2026</div>
        <div class="post-title">Before the Bloom</div>
        <div class="post-excerpt">Mud season is over. Something new is about to arrive in the hills.</div>
      </li>
      <li class="post-item">
        <div class="post-meta">Apr 9, 2026</div>
        <div class="post-title">Fairy Shrimp & Vernal Pools</div>
        <div class="post-excerpt">The miniature world that wakes up only after the snow melts.</div>
      </li>
      <li class="post-item">
        <div class="post-meta">Apr 2, 2026</div>
        <div class="post-title">Spring Lands All at Once</div>
        <div class="post-excerpt">One week of rain, one week of warmth — and the whole county changed.</div>
      </li>
      <li class="post-item">
        <div class="post-meta">Mar 26, 2026</div>
        <div class="post-title">The Bantam River in March</div>
        <div class="post-excerpt">Cold, fast, and full of itself. The river at its most honest.</div>
      </li>
    </ul>
    <div class="subscribe-box">
      <div class="subscribe-box-label">Get the Newsletter</div>
      <p class="subscribe-box-copy">Every Thursday in your inbox.</p>
      <div class="beehiiv-wrap" style="margin-top: 0;">
        <script is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="48c597c3-c9e3-4c7a-b09b-db8627e0a48e"></script>
      </div>
    </div>
  </main>
</div>

<footer>
  <div class="footer-logo">The Litchfield Ledger</div>
  <div class="footer-sub">Litchfield County, Connecticut</div>
  <div class="beehiiv-wrap" style="margin-top: 0;">
    <script is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="48c597c3-c9e3-4c7a-b09b-db8627e0a48e"></script>
  </div>
  <div class="footer-nav">
    <a href="#">Archive</a>
    <a href="#">Events</a>
    <a href="#">Contact</a>
  </div>
  <p class="footer-copy">© 2026 The Litchfield Ledger</p>
</footer>

<script is:inline>
(function () {
  const LAT = 41.7448, LNG = -73.2354;

  function doy(date) {
    return Math.floor((date - new Date(date.getFullYear(), 0, 0)) / 86400000);
  }

  function emerging(d) {
    if (d < 74)  return 'Dormant';
    if (d < 85)  return 'Skunk cabbage, hepatica';
    if (d < 100) return 'Bloodroot, spring beauty';
    if (d < 115) return 'Trout lily, coltsfoot';
    if (d < 130) return 'Wild ginger, jack-in-the-pulpit';
    if (d < 150) return 'Mayapple, wild columbine';
    if (d < 166) return 'Mountain laurel';
    return 'Summer flora';
  }

  function springPct(d) {
    return Math.max(0, Math.min(100, Math.round(((d - 74) / (166 - 74)) * 100)));
  }

  function springStage(p) {
    if (p < 18) return 'Mud';
    if (p < 45) return 'Before Bloom';
    if (p < 72) return 'Peak';
    return 'Summer';
  }

  function trailCond(mm) {
    if (mm > 25) return { l: 'Muddy',  n: 'boots req.',   cls: 'caution', dot: '#c85c1e' };
    if (mm > 10) return { l: 'Soft',   n: 'wet in spots', cls: 'caution', dot: '#c85c1e' };
    if (mm > 3)  return { l: 'Damp',   n: 'mostly firm',  cls: 'good',    dot: '#2a5236' };
    return             { l: 'Good',   n: 'firm & dry',   cls: 'good',    dot: '#1e3d28' };
  }

  function sunFmt(iso) {
    const d = new Date(iso), h = d.getHours(), m = d.getMinutes().toString().padStart(2, '0');
    return `${h % 12 || 12}:${m} <span class="unit">${h >= 12 ? 'PM' : 'AM'}</span>`;
  }

  function row(label, valueHTML, cls) {
    return `<div class="field-row">
      <span class="field-label">${label}</span>
      <span class="field-value ${cls || ''}">${valueHTML}</span>
    </div>`;
  }

  const now   = new Date();
  const month = now.getMonth() + 1;
  const d     = doy(now);
  const pct   = springPct(d);
  const stage = springStage(pct);

  document.getElementById('fr-date').textContent =
    now.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) +
    ' — Litchfield County';

  Promise.allSettled([
    fetch(`https://api.sunrise-sunset.org/json?lat=${LAT}&lng=${LNG}&formatted=0`).then(r => r.json()),
    fetch(`https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LNG}&daily=temperature_2m_mean,precipitation_sum&past_days=14&forecast_days=0&timezone=America%2FNew_York`).then(r => r.json()),
  ]).then(([sunRes, weatherRes]) => {

    let sunHTML = '—';
    if (sunRes.status === 'fulfilled') {
      const s = sunRes.value.results;
      sunHTML = `${sunFmt(s.sunrise)} <span style="color:#ccc;margin:0 4px">/</span> ${sunFmt(s.sunset)}`;
    }

    let lakeTempHTML = '<span style="color:var(--text-muted)">—</span>';
    let lakeClass = '';
    if (weatherRes.status === 'fulfilled') {
      const temps = weatherRes.value.daily?.temperature_2m_mean || [];
      if (temps.length) {
        const avg  = temps.filter(Boolean).reduce((a, b) => a + b, 0) / temps.filter(Boolean).length;
        const lag  = month <= 4 ? 14 : month === 5 ? 10 : 6;
        const temp = Math.round((avg * 9 / 5 + 32) - lag);
        lakeTempHTML = `${temp}°<span class="unit">F — est.</span>`;
        lakeClass = 'good';
      }
    }

    let trailHTML = 'Unknown<span class="unit">— check locally</span>';
    let trailClass = '';
    if (weatherRes.status === 'fulfilled') {
      const precip = (weatherRes.value.daily?.precipitation_sum || []).slice(-3);
      const total  = precip.reduce((a, b) => a + (b || 0), 0);
      const tc     = trailCond(total);
      trailHTML = `<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${tc.dot};margin-right:5px;vertical-align:middle;"></span>${tc.l}<span class="unit">— ${tc.n}</span>`;
      trailClass = tc.cls;
    }

    document.getElementById('fr-live').textContent =
      'Live · ' + now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

    document.getElementById('fr-body').innerHTML = `
      ${row('Bantam Lake', lakeTempHTML, lakeClass)}
      ${row('Trail Conditions', trailHTML, trailClass)}
      ${row('Sunrise / Sunset', sunHTML)}
      <div class="phenology-bar">
        <div class="pheno-label">Spring Progression</div>
        <div class="pheno-track"><div class="pheno-fill" style="width:${pct}%"></div></div>
        <div class="pheno-stages">
          ${['Mud','Before Bloom','Peak','Summer'].map(s =>
            `<span class="pheno-stage ${s === stage ? 'active' : ''}">${s}</span>`
          ).join('')}
        </div>
      </div>
      ${row("What's Emerging", `<em style="font-size:13px">${emerging(d)}</em>`)}
    `;
  });
})();
</script>

</body>
</html>